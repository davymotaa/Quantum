# Copie este arquivo para .env e preencha suas chaves

# OpenAI
OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=gpt-5.4-mini

# LM Studio / Sultry Silicon
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=sultrysilicon-7b-v2

# Google Docs / Oráculo
ORACULO_DOCS_CONFIG=oraculo/docs.json
VOL_IV_DOC_URL=https://docs.google.com/document/d/1-BwgZEy83W_B8OvziGCMvwLpI2CdQ99m6ZjyEVvaqbo

# Banco de dados (SQLite local por padrão)
DATABASE_URL=sqlite:///./quantum_ai.db
